function public main() {
    print("Running");
    set Int i = 4;
    run add(5, @i);
    print(@add_output);
};

function public add(Int a, Int b){
    change @a + @b;
    return Int add_output as @a;
};

run main();

set Int a = 1;

if (1 == @a) {
    print("True");
};
else {
    print("False");
};
