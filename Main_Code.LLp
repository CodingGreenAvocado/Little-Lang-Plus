pull Math;

function public main() {
    print("Running");
    set Int i = 4;
    lib Math.add(5, @i, "add_output");
    print(@add_output);
};

function public test_if() {
    print("Testing");
    if (1 == 1) {
        print("It works");
    };
    else {
        print("works?");
    };
    print("Done");
};

run main();
lib Math.add(5, 2, "add_output");
print(@add_output);
run test_if();

set Int i = 0;
while (@i < 5) {
    change @i + 1;
    print(@i);
};
